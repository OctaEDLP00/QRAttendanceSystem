{
  "name": "qr-attendance-system-fullstack",
  "version": "1.0.0",
  "description": "A QR code-based attendance system built with NestJS, Prisma, Astro and Expo.",
  "scripts": {
    "build": "pnpm --filter types build && pnpm --filter backend build && pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:types": "pnpm --filter types build",
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "start:backend": "pnpm --filter backend start",
    "start:mobile": "pnpm --filter mobile start",
    "test:backend": "pnpm --filter backend test",
    "test:e2e:backend": "pnpm --filter backend test:e2e",
    "lint:backend": "pnpm --filter backend lint",
    "lint:mobile": "pnpm --filter mobile lint",
    "format:backend": "pnpm --filter backend format",
    "db:generate": "pnpm --filter backend db:generate",
    "db:push": "pnpm --filter backend db:push",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:studio": "pnpm --filter backend db:studio",
    "db:seed": "pnpm --filter backend db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs"
  },
  "workspaces": [
    "./backend",
    "./frontend",
    "./mobile"
  ],
  "devDependencies": {
    "typescript": "6.0.2"
  }
}
